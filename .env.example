# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
INTERNAL_API_TOKEN=your-internal-ingest-token
INGEST_ENDPOINT_URL=http://localhost:3000/api/internal/ingest/feed-state
INGEST_INTERVAL_MS=3000
CAMERA_SOURCE_MODE=url
CAMERA_SOURCE_URL=http://localhost:4000/feeds
REMOTE_STALE_THRESHOLD_MS=15000
LOCAL_FEED_SESSION_TTL_SECONDS=1800
SHADOW_MODE_ENABLED=true
SHADOW_MODEL_MODE=adapter
SHADOW_MODEL_ADAPTER_URL=http://localhost:5050/shadow/infer
SHADOW_MODEL_TIMEOUT_MS=2500
SHADOW_MODEL_FALLBACK_TO_HEURISTIC=true
SHADOW_YOLO_MODEL=backend/best.pt
SHADOW_YOLO_CONF=0.25
SHADOW_YOLO_IMGSZ=640
SHADOW_CAPTURE_LOCAL_DEVICE=false
SHADOW_DEBUG_LOGS=false
SHADOW_DEBUG_MAX_BOXES=12
# Map camera IDs to local sources (camera index, RTSP URL, file, etc)
# Example: SHADOW_CAMERA_SOURCES={"CAM-201":"rtsp://127.0.0.1:8554/cam1"}
SHADOW_CAMERA_SOURCES={}
